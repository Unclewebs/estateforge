generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  BUYER
  SELLER
  AGENT
  ADMIN
}

enum PropertyType {
  HOUSE
  APARTMENT
  CONDO
  VILLA
  LAND
  COMMERCIAL
  TOWNHOUSE
  STUDIO
}

enum PropertyStatus {
  FOR_SALE
  FOR_RENT
  SOLD
  RENTED
  PENDING
  ARCHIVED
}

model User {
  id            String   @id @default(cuid())
  clerkId       String   @unique
  email         String   @unique
  firstName     String?
  lastName      String?
  imageUrl      String?
  phone         String?
  bio           String?
  roles         Role[]   @default([BUYER])
  activeRole    Role     @default(BUYER)
  licenseNumber String?
  agency        String?
  yearsExperience Int?
  specializations String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  properties       Property[]     @relation("PropertyOwner")
  agentListings    Property[]     @relation("PropertyAgent")
  favorites        Favorite[]
  savedSearches    SavedSearch[]
  sentMessages     Message[]      @relation("MessageSender")
  receivedMessages Message[]      @relation("MessageReceiver")
  inquiries        Inquiry[]      @relation("InquiryFrom")
  agentInquiries   Inquiry[]      @relation("InquiryTo")
  notifications    Notification[]

  @@index([clerkId])
  @@index([email])
}

model Property {
  id            String         @id @default(cuid())
  slug          String         @unique
  title         String
  description   String
  price         Float
  propertyType  PropertyType
  status        PropertyStatus @default(FOR_SALE)
  bedrooms      Int?
  bathrooms     Int?
  squareFeet    Float?
  lotSize       Float?
  yearBuilt     Int?
  parking       Int?
  stories       Int?
  address       String
  city          String
  state         String
  zipCode       String
  country       String         @default("US")
  latitude      Float?
  longitude     Float?
  images        String[]
  virtualTourUrl String?
  amenities     String[]
  featured      Boolean        @default(false)
  views         Int            @default(0)
  expiresAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  ownerId       String
  owner         User           @relation("PropertyOwner", fields: [ownerId], references: [id])
  agentId       String?
  agent         User?          @relation("PropertyAgent", fields: [agentId], references: [id])
  favorites     Favorite[]
  inquiries     Inquiry[]

  @@index([slug])
  @@index([ownerId])
  @@index([agentId])
  @@index([status])
  @@index([propertyType])
  @@index([city, state])
  @@index([price])
  @@index([latitude, longitude])
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
}

model SavedSearch {
  id           String   @id @default(cuid())
  userId       String
  name         String
  filters      Json
  alertEnabled Boolean  @default(true)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Inquiry {
  id         String   @id @default(cuid())
  message    String
  propertyId String
  fromUserId String
  toUserId   String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  fromUser   User     @relation("InquiryFrom", fields: [fromUserId], references: [id])
  toUser     User     @relation("InquiryTo", fields: [toUserId], references: [id])

  @@index([propertyId])
  @@index([toUserId])
}

model Message {
  id         String   @id @default(cuid())
  content    String
  senderId   String
  receiverId String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  sender     User     @relation("MessageSender", fields: [senderId], references: [id])
  receiver   User     @relation("MessageReceiver", fields: [receiverId], references: [id])

  @@index([senderId, receiverId])
  @@index([receiverId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
